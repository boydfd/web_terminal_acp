APP_HOST=127.0.0.1
APP_PORT=8000
DATABASE_URL=postgresql+asyncpg://web_terminal:dev_password@127.0.0.1:15436/web_terminal_acp
POSTGRES_LOG_MIN_DURATION_STATEMENT_MS=500
ELASTICSEARCH_URL=http://127.0.0.1:19201
REDIS_URL=redis://127.0.0.1:16379/0
WEB_TERMINAL_AUTH_SECRET=
WEB_TERMINAL_AUTH_SESSION_TTL_SECONDS=604800
TMUX_POOL_SESSION=web_terminal_acp_pool
# auto uses the backend/client user's login shell. Set /bin/bash or /usr/bin/zsh to force one.
DEFAULT_SHELL=auto
CLAUDE_PROJECTS_DIR=~/.claude/projects
HOST_CLAUDE_CONFIG_DIR=~/.claude
HOST_CLAUDE_JSON=~/.claude.json
CODEX_CONFIG_DIR=~/.codex
AGENTS_CONFIG_DIR=~/.agents
ACPX_CONFIG_DIR=~/.acpx
WORKSPACE_DIR=~/workspace
DEBIAN_MIRROR=
NODE_VERSION=22.22.3
NPM_REGISTRY=

# Docker frontend build skips electron binary download (see frontend/Dockerfile).
# For local electron:dev, do NOT set ELECTRON_SKIP_BINARY_DOWNLOAD.
# HTTP_PROXY/HTTPS_PROXY are not wired into docker-compose builds; the npm registry
# mirror above is usually enough. Electron downloads from GitHub, not npm.
# ELECTRON_SKIP_BINARY_DOWNLOAD=1

# LLM used by the summary worker (OpenAI-compatible API).
OPENAI_COMPAT_BASE_URL=http://127.0.0.1:11434/v1
OPENAI_COMPAT_API_KEY=dev-local-key
OPENAI_COMPAT_MODEL=local-summarizer
OPENAI_COMPAT_TIMEOUT_SECONDS=60

# Terminal auto-summary scheduling (backend Settings).
# Shell user input: schedule after idle; each new command resets the idle timer.
# Only terminal_input_command events count — terminal output and agent events do not extend idle.
TERMINAL_SUMMARY_IDLE_SECONDS=20
# First summary cap while input keeps arriving (min of idle and this window from first command).
TERMINAL_SUMMARY_INITIAL_MAX_WAIT_SECONDS=120
# Minimum interval between summaries after the first succeeded job.
TERMINAL_SUMMARY_REPEAT_SECONDS=600
# Max bytes of command history sent to the summarizer per window.
TERMINAL_SUMMARY_INPUT_CONTEXT_MAX_BYTES=32768
# Language hint for generated title/summary text (e.g. 中文, English).
SUMMARY_OUTPUT_LANGUAGE=中文

# Leave empty for the Docker frontend so nginx proxies /api and WebSocket traffic
# to the backend container. For local Vite development, use http://127.0.0.1:8000.
VITE_API_BASE=
# New-user onboarding is disabled by default. Set to true before building the
# frontend image when you want the UI walkthrough and restart button.
VITE_ENABLE_ONBOARDING=
